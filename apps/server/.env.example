# Real backend (Hono) config. Copy to `.env` and fill in to run `npm run dev:real`.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any OpenRouter model id, e.g. anthropic/claude-sonnet-4.5, openai/gpt-4o, etc.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Port the Hono server listens on (Vite proxies /api here). Optional.
PORT=8787
# Override the block remotes' remoteEntry.js URLs (e.g. a CDN in prod). Optional
# — default to the local dev remotes.
BLOCKS_SPEND_ENTRY=http://localhost:9998/remoteEntry.js
BLOCKS_PORTFOLIO_ENTRY=http://localhost:9997/remoteEntry.js
