{
  "name": "bank-ai-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @bank-ai/web",
    "dev:real": "concurrently -k -n server,web -c green,cyan \"npm run server -w @bank-ai/server\" \"npm run dev -w @bank-ai/web -- --mode real\"",
    "server": "npm run server -w @bank-ai/server",
    "build": "tsc -b && npm run build -w @bank-ai/web",
    "lint": "oxlint",
    "preview": "npm run preview -w @bank-ai/web"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2"
  }
}
